<div class="booking-card list-group-item p-0 rounded wunderbyteTableJavascript search-data-element"
    {{#datafields}}
        data-{{key}}="{{value}}"
    {{/datafields}}
>
    <div class="booking-card__media">
        {{#cardimage}}
            {{#value}}
                <img class="booking-card__image" src="{{{value}}}" {{#cardimagealt}}alt="{{.}}" title="{{.}}"{{/cardimagealt}}>
            {{/value}}
            {{^value}}
                <div class="booking-card__image-placeholder"></div>
            {{/value}}
        {{/cardimage}}
    </div>

    <div class="booking-card__content">

        <div class="booking-card__top">
            <div class="booking-card__status">
                {{{statusbadge}}}
            </div>

            <div class="booking-card__capacity">
                {{{capacity}}}
            </div>
        </div>

        <div class="booking-card__titlearea">
            {{#title}}
                <h3 class="booking-card__title">{{{title}}}</h3>
            {{/title}}
        </div>

        <div class="booking-card__descriptionarea">
            {{#description}}
                <div class="booking-card__description">{{{description}}}</div>
            {{/description}}
        </div>

        <div class="booking-card__metaarea">
            {{#hasmetaitems}}
                <ul class="booking-card__meta infolist">
                    {{#metaitems}}
                        <li class="booking-card__meta-item {{key}}">
                            {{#icon}}
                                <i class="{{icon}}" aria-hidden="true"></i>
                            {{/icon}}
                            <span class="booking-card__meta-value">{{{value}}}</span>
                        </li>
                    {{/metaitems}}
                </ul>
            {{/hasmetaitems}}
        </div>

        <div class="booking-card__tagsarea">
            {{#hastags}}
                <div class="booking-card__tags">
                {{#tags.0}}<i class="fa fa-hashtag text-primary" aria-hidden="true"></i>{{/tags.0}}
                    {{#tags}}
                        <span class="booking-card__tag">{{{value}}}</span>
                    {{/tags}}
                </div>
            {{/hastags}}
        </div>

        <div class="booking-card__actions">
            {{#secondaryaction}}
                <div class="booking-card__action booking-card__action--secondary">
                    {{{secondaryaction}}}
                </div>
            {{/secondaryaction}}

            {{#primaryaction}}
                <div class="booking-card__action booking-card__action--primary">
                    {{{primaryaction}}}
                </div>
            {{/primaryaction}}
        </div>
    </div>
</div>

<style>

.booking-card {
    display: grid;
    grid-template-rows: 220px 1fr;
    height: 100%;
    max-width: 25rem;
    border: 1px solid #d9d9d9;
    background: #fff;
}

.booking-card__media {
    height: 220px;
    overflow: hidden;
}

.booking-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.booking-card__image-placeholder {
    height: 100%;
    background-color: #e6f0f7;
    opacity: 0.8;
    background-image: radial-gradient(#45aaf7 0.5px, #e6f0f7 0.5px);
    background-size: 10px 10px;
}

.booking-card__content {
    display: grid;
    grid-template-rows:
        3.5rem
        8.5rem
        8rem
        1fr
        3.5rem
        4rem;
    gap: 1rem;
    padding: 1.5rem;
    height: 100%;
}

.booking-card__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    min-height: 3.5rem;
}

.booking-card__titlearea {
    min-height: 8.5rem;
}

.booking-card__title {
    margin: 0;
    font-size: 2rem;
    line-height: 1.2;
    font-weight: 700;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.booking-card__descriptionarea {
    min-height: 8rem;
}

.booking-card__description {
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.booking-card__metaarea {
    min-height: 8rem;
}

.booking-card__meta {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
}

.booking-card__meta-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    line-height: 1.3;
}

.booking-card__meta-item i {
    flex: 0 0 1.25rem;
}

.booking-card__tagsarea {
    min-height: 3.5rem;
    display: flex;
    align-items: center;
}

.booking-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.booking-card__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.9rem;
    border: 1px solid #d6d6d6;
    border-radius: 999px;
    background: #f8f8f8;
    line-height: 1;
    white-space: nowrap;
}

.booking-card__actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
    min-height: 4rem;
}
</style>