{{!
    @template mod_booking/table_cards_row
    Template which defines a mooduell view page.
    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * statistics - array: An array with values.
    * opengames - array: empty array, will be filled with JS.
    * finishedgames - array: empty array, will be filled with JS.
    * highscores - array: empty array, will be filled with JS.

    Example context (json):

    {
      "rowid": "allbookingoptionstable_r1",
      "rowclasses": "rowclasses",
      "datafields": [
        {
          "key": "field1",
          "value": "value1"
        }
      ],
      "leftside": {
        "invisibleoption": {
          "columnkeyclass": "d-none",
          "columnvalueclass": "booking-option-info-invisible"
        },
        "text": {
          "columnkeyclass": "d-none",
          "columnclass": "text-start m-0 mb-1 h5",
          "keystring": "Course name"
        },
        "action": {
          "columnkeyclass": "d-none",
          "columnclass": "text-end"
        },
        "teacher": {
          "columnkeyclass": "d-none",
          "columnclass": "text-start font-size-sm",
          "keystring": "Teacher(s)"
        },
        "statusdescription": {
          "columnkeyclass": "d-none"
        },
        "description": {
          "columnkeyclass": "d-none"
        }
      },
      "footer": {
        "bookings": {
          "columnkeyclass": "d-none",
          "columnclass": "text-start text-gray pe-2 font-size-sm",
          "columniclassbefore": "fa fa-ticket fa-fw text-gray font-size-sm"
        },
        "minanswers": {
          "columnkeyclass": "d-none",
          "columnclass": "text-start text-gray pe-2 font-size-sm",
          "columniclassbefore": "fa fa-arrow-up fa-fw text-gray font-size-sm"
        },
        "dayofweektime": {
          "columnkeyclass": "d-none",
          "columnclass": "text-start text-gray pe-2 font-size-sm",
          "columniclassbefore": "fa fa-clock-o fa-fw text-gray font-size-sm"
        },
        "location": {
          "columnkeyclass": "d-none",
          "columnclass": "text-start text-gray  pe-2 font-size-sm",
          "columniclassbefore": "fa fa-map-marker fa-fw text-gray font-size-sm"
        },
        "institution": {
          "columnkeyclass": "d-none",
          "columnclass": "text-start text-gray  pe-2 font-size-sm",
          "columniclassbefore": "fa fa-building-o fa-fw text-gray font-size-sm"
        },
        "responsiblecontact": {
          "columnkeyclass": "d-none",
          "columnclass": "text-start text-gray  pe-2 font-size-sm",
          "columniclassbefore": "fa fa-user fa-fw text-gray font-size-sm"
        },
        "showdates": {
          "columnkeyclass": "d-none",
          "columnclass": "text-start pe-2 text-gray font-size-sm"
        },
        "comments": {
          "columnkeyclass": "d-none"
        }
      },
      "rightside": {
        "booknow": {
          "columnclass": "text-end"
        },
        "course": [],
        "progressbar": {
          "columnclass": "text-start mt-1 text-gray font-size-sm"
        },
        "ratings": {
          "columnclass": "mt-1"
        }
      }
    }
}}

<div class="list-group-item p-0 rounded wunderbyteTableJavascript search-data-element d-flex flex-column"
    style="max-width: 25rem;"
    {{#datafields}}
        data-{{key}}="{{value}}"
    {{/datafields}}
>
  <div class="mod-booking-view-card-image-and-body-area mod-booking-row">
    {{#cardimage}}
      {{#value}}
        <img class="mod-booking-view-card-image" src="{{{value}}}" {{#cardimagealt}}alt="{{.}}" title="{{.}}"{{/cardimagealt}}>
      {{/value}}
      {{^value}}
        <div
          style="height: 220px; background-color: #e6f0f7;
                opacity: 0.8;
                background-image: radial-gradient(#45aaf7 0.5px, #e6f0f7 0.5px);
                background-size: 10px 10px;">
        </div>
      {{/value}}
    {{/cardimage}}

    <div class="{{cardbodyclass}} mt-2 ms-2 me-2 p-2">
      {{#cardbody}}
        {{#columnclass}}<div class="{{.}}{{#key}} {{key}}{{/key}}">{{/columnclass}}

          {{#value}}
            {{#columniclassbefore}}
              <i class="{{.}}" aria-hidden="true"></i>
            {{/columniclassbefore}}
          {{/value}}

          {{#columnkeyclass}}<span class="key {{.}}">{{/columnkeyclass}}
            {{^keystring}}
              {{{key}}}
            {{/keystring}}
            {{#keystring}}
              {{.}}:
            {{/keystring}}
          {{#columnkeyclass}}</span>{{/columnkeyclass}}

          {{#value}}
            <span class="{{columnvalueclass}}{{#key}} {{key}}{{/key}}">
              {{{value}}}
            </span>
          {{/value}}

          {{#value}}
            {{#columniclassafter}}
              <i class="value {{.}}" aria-hidden="true"></i>
            {{/columniclassafter}}
          {{/value}}

        {{#columnclass}}</div>{{/columnclass}}
      {{/cardbody}}
    </div>

    <div class="mt-2 ms-3 me-3">
      <div class="{{cardlistclass}}">
        <ul class="infolist">
        {{#cardlist}}
          {{#value}}
            <li {{#columnalt}}title="{{.}}"{{/columnalt}}>
              {{#columnclass}}<div class="{{.}}{{#key}} {{key}}{{/key}}">{{/columnclass}}

                {{#columniclassbefore}}
                  <i class="{{.}}" aria-hidden="true"></i>
                {{/columniclassbefore}}

                {{#columnkeyclass}}
                  <span class="key {{.}}">
                {{/columnkeyclass}}

                  {{^keystring}}
                    {{{key}}}
                  {{/keystring}}

                  {{#keystring}}
                    {{.}}:
                  {{/keystring}}

                {{#columnkeyclass}}
                  </span>
                {{/columnkeyclass}}

                <span class="{{columnvalueclass}}{{#key}} {{key}}{{/key}}">
                  {{{value}}}
                </span>

                {{#columniclassafter}}
                  <i class="value {{.}}" aria-hidden="true"></i>
                {{/columniclassafter}}

              {{#columnclass}}</div>{{/columnclass}}
            </li>
          {{/value}}
        {{/cardlist}}
        </ul>
      </div>
    </div>
  </div>

  <div class="mod-booking-view-card-mainarea mt-auto">
    <div class="mt-2 text-center p-2">
      {{#cardfooter}}
        {{#columnclass}}<div class="{{.}}{{#key}} {{key}}{{/key}}">{{/columnclass}}

          {{#value}}
            {{#columniclassbefore}}
              <i class="{{.}}" aria-hidden="true"></i>
            {{/columniclassbefore}}
          {{/value}}

          {{#columnkeyclass}}<span class="key {{.}}">{{/columnkeyclass}}
            {{^keystring}}
              {{{key}}}
            {{/keystring}}
            {{#keystring}}
              {{.}}:
            {{/keystring}}
          {{#columnkeyclass}}</span>{{/columnkeyclass}}

          {{#value}}
            <div class="{{columnvalueclass}}{{#key}} {{key}}{{/key}}">
              {{{value}}}
            </div>
          {{/value}}

          {{#value}}
            {{#columniclassafter}}
              <i class="value {{.}}" aria-hidden="true"></i>
            {{/columniclassafter}}
          {{/value}}

        {{#columnclass}}</div>{{/columnclass}}
      {{/cardfooter}}
    </div>
  </div>
</div>