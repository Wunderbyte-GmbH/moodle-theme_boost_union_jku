{{!
    @template local_wunderbyte_table/pagination
    Template which defines a mooduell view page.
    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    * statistics - array: An array with values.
    * opengames - array: empty array, will be filled with JS.
    * finishedgames - array: empty array, will be filled with JS.
    * highscores - array: empty array, will be filled with JS.

    Example context (json):
    {
       "nopages" : "nopages",
       "previouspage": "1",
       "disableprevious": "disabled",
       "nextpage": "3",
       "disablenext": "disabled",
       "pages" : [
        {
           "active" : "active",
           "pagenumber" : "2",
           "ellipsis" : "ellipsis"
       }
       ]
    }

}}

{{^nopages}}
    <div class="wbt-pagination-navs mt-3">
        <nav class="wbt-pagination-wrapper"
             aria-label="{{#str}} page, core {{/str}}">

            <ul class="pagination wbt-pagination">
                <li class="page-item {{disableprevious}}"
                    data-pagenumber="{{previouspage}}">

                    <a class="page-link wbt-pagination__navigation"
                       role="button"
                       aria-label="{{#str}} previous, core {{/str}}"
                       {{#disableprevious}}
                           aria-disabled="true"
                           tabindex="-1"
                       {{/disableprevious}}>

                        <span aria-hidden="true">←</span>
                        <span>{{#str}} previous, core {{/str}}</span>
                    </a>
                </li>

                {{#pages}}
                    {{^ellipsis}}
                        <li class="page-item {{active}}"
                            data-pagenumber="{{pagenumber}}">

                            <a class="page-link"
                               role="button"
                               aria-label="{{#str}} page, core {{/str}} {{pagenumber}}"
                               {{#active}}aria-current="page"{{/active}}>
                                {{pagenumber}}
                            </a>
                        </li>
                    {{/ellipsis}}

                    {{#ellipsis}}
                        <li class="page-item disabled">
                            <span class="page-link wbt-pagination__ellipsis"
                                  aria-hidden="true">
                                …
                            </span>
                        </li>
                    {{/ellipsis}}
                {{/pages}}

                <li class="page-item {{disablenext}}"
                    data-pagenumber="{{nextpage}}">

                    <a class="page-link wbt-pagination__navigation"
                       role="button"
                       aria-label="{{#str}} next, core {{/str}}"
                       {{#disablenext}}
                           aria-disabled="true"
                           tabindex="-1"
                       {{/disablenext}}>

                        <span>{{#str}} next, core {{/str}}</span>
                        <span aria-hidden="true">→</span>
                    </a>
                </li>
            </ul>
        </nav>

        {{#gotopage}}
            <div class="wbt-gotopage">
                <label for="wbt-go-to-page">
                    {{#str}} gotopage, local_wunderbyte_table {{/str}}
                </label>

                <select id="wbt-go-to-page"
                        class="form-select go-to-page-select"
                        data-initial-value="5">
                    {{#totalpages}}
                        <option value="{{value}}" {{#selected}}selected{{/selected}}>
                            {{value}}
                        </option>
                    {{/totalpages}}
                </select>
            </div>
        {{/gotopage}}
    </div>
{{/nopages}}
<style>
.wbt-pagination-navs {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: var(--Spacing-24, 24px);
}

.wbt-pagination-wrapper {
    min-width: 0;
}

.pagination.wbt-pagination {
    display: flex;
    margin: 0;
    padding: 0 0 0 var(--Spacing-16, 16px);
    align-items: center;
    align-self: stretch;
    gap: var(--Spacing-8, 8px);
    flex-wrap: wrap;
    list-style: none;

    .page-item {
        margin: 0;
    }

    .page-link {
        display: inline-flex;
        min-width: 40px;
        height: 40px;
        margin: 0;
        padding: var(--Spacing-8, 8px) var(--Spacing-12, 12px);
        align-items: center;
        justify-content: center;
        border: 1px solid transparent;
        border-radius: 4px;
        background: transparent;
        color: var(--gray-900, #1d2125);
        font-size: 14px;
        font-weight: 400;
        line-height: 1;
        text-decoration: none;
        box-shadow: none;
        cursor: pointer;

        &:hover {
            border-color: var(--gray-400, #b8c0c5);
            background: var(--gray-100, #f5f6f7);
            color: var(--gray-900, #1d2125);
        }

        &:focus-visible {
            border-color: var(--primary, #0f6cbf);
            outline: 2px solid var(--primary, #0f6cbf);
            outline-offset: 2px;
            box-shadow: none;
        }
    }

    .page-item.active .page-link {
        border-color: var(--gray-600, #6a737b);
        background: var(--white, #fff);
        color: var(--gray-900, #1d2125);
        font-weight: 400;
        z-index: auto;
    }

    .page-item.disabled .page-link {
        border-color: transparent;
        background: transparent;
        color: var(--gray-600, #6a737b);
        opacity: 1;
        pointer-events: none;
        cursor: default;
    }

    .wbt-pagination__navigation {
        min-width: auto;
        gap: var(--Spacing-8, 8px);
        white-space: nowrap;
    }

    .wbt-pagination__ellipsis {
        min-width: auto;
        padding-right: var(--Spacing-4, 4px);
        padding-left: var(--Spacing-4, 4px);
    }
}

.wbt-gotopage {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    gap: var(--Spacing-8, 8px);

    label {
        margin: 0;
        white-space: nowrap;
    }

    .go-to-page-select {
        width: auto;
        min-width: 72px;
    }
}

@media (max-width: 767.98px) {
    .wbt-pagination-navs {
        align-items: flex-start;
        flex-direction: column;
    }

    .pagination.wbt-pagination {
        padding-left: 0;
    }
}
</style>