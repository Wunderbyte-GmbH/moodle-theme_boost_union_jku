{{!
    @template mod_mooduell/viewpage
    Template which defines a mooduell view page.
    Classes required for JS:
    * none
    Data attributes required for JS:
    * none
    Context variables required for this template:
    Example context (json):
    {
        "categories" : [
            [
               {
                  "catid":"7",
                  "contextid":"1",
                  "catname":"MooDuell Pr\u00e4sentation",
                  "courseid":"50"
               }
            ]
        ]
    }
}}

<li class="wb_faq-accordion-item" data-id="{{id}}" data-sortorder="{{sortorder}}">

  {{#canedit}}
  <span class="wb_faq-accordion-drag" tabindex="0" role="button" aria-haspopup="true" data-drag-type="move" title="{{{title}}}">
    <i class="fa fa-arrows"></i>
  </span>
  {{/canedit}}

  <div class="wb_faq-accordion-card">
    <div class="wb_faq-accordion-header" id="heading-{{id}}-{{uid}}">

      <button
        class="wb_faq-accordion-button py-16 {{^open}}collapsed{{/open}}"
        type="button"
        data-toggle="collapse"
        data-bs-toggle="collapse"
        data-target="#collapse-{{id}}-{{uid}}"
        data-bs-target="#collapse-{{id}}-{{uid}}"
        aria-expanded="{{#open}}true{{/open}}{{^open}}false{{/open}}"
        aria-controls="collapse-{{id}}-{{uid}}"
      >
        <span class="wb_faq-accordion-title">{{{title}}}</span>

        {{^canedit}}
        <span class="wb_faq-accordion-chevron" aria-hidden="true"></span>
        {{/canedit}}
      </button>

      {{#canedit}}
      <div class="wb_faq-accordion-actions">
        {{#enabled}}
        <a class="local_wb_faq_toggle_entry_visibility" data-id="{{id}}">
          <i class="toggle-visibility fa fa-eye"></i>
        </a>
        {{/enabled}}

        {{^enabled}}
        <a class="local_wb_faq_toggle_entry_visibility" data-id="{{id}}">
          <i class="toggle-visibility fa fa-eye-slash"></i>
        </a>
        {{/enabled}}

        <a class="local_wb_faq_edit_question" data-id="{{id}}">
          <i class="fa fa-pencil"></i>
        </a>

        <a class="local_wb_faq_delete_question" data-id="{{id}}">
          <i class="fa fa-trash-o"></i>
        </a>
      </div>
      {{/canedit}}

    </div>

    <div
      id="collapse-{{id}}-{{uid}}"
      class="accordion-collapse collapse {{#open}}show{{/open}}"
      aria-labelledby="heading-{{id}}-{{uid}}"
    >
      <div class="wb_faq-accordion-body">
        <div class="wb_faq-accordion-content">
          {{{content}}}
        </div>
      </div>
    </div>
  </div>
</li>



