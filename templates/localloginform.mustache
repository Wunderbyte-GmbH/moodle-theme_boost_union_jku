<div class="custom-login-page">
    <div class="custom-login-left">
        <div class="custom-login-logo">
            JOHANNES KEPLER<br>UNIVERSITÄT LINZ
        </div>

        <div class="custom-login-box">
            <h1>Willkommen</h1>
            <p>Logge dich hier mit deinem Benutzer ein</p>

            {{#errormsg}}
                <div class="alert alert-warning">{{{errormsg}}}</div>
            {{/errormsg}}

            {{#identityproviders}}
                <a class="custom-sso-btn" href="{{url}}">
                    <span>G</span>
                    Einloggen mit {{name}}
                </a>
            {{/identityproviders}}

            <div class="custom-divider">
                <span></span>
                <strong>ODER</strong>
                <span></span>
            </div>

            <form action="{{loginurl}}" method="post" id="login">
                <input type="hidden" name="logintoken" value="{{logintoken}}">

                <label for="username">Email</label>
                <input type="text" name="username" id="username" class="form-control">

                <label for="password">Passwort</label>
                <input type="password" name="password" id="password" class="form-control">

                <a class="custom-forgot" href="{{forgetpassword}}">
                    Passwort vergessen?
                </a>

                <button class="custom-login-btn" type="submit" id="loginbtn">
                    Log in
                </button>
            </form>

            <div class="custom-register">
                Du hast noch keinen Account?
                <a href="{{signupurl}}">Melde dich hier an</a>
            </div>
        </div>
    </div>

    <div class="custom-login-right"></div>
</div>

<style>

.custom-login-page {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 50% 50%;
    background: #fff;
}

.custom-login-left {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
}

.custom-login-logo {
    position: absolute;
    top: 28px;
    left: 64px;
    font-size: 10px;
    font-weight: 800;
    line-height: 1.1;
}

.custom-login-box {
    width: 100%;
    max-width: 430px;
}

.custom-login-box h1 {
    font-size: 52px;
    font-weight: 800;
    margin-bottom: 12px;
}

.custom-login-box p {
    font-size: 18px;
    color: #555;
    margin-bottom: 55px;
}

.custom-sso-btn {
    height: 56px;
    border: 2px solid #111;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    font-weight: 700;
    color: #111;
    text-decoration: none;
    margin-bottom: 45px;
}

.custom-divider {
    display: flex;
    align-items: center;
    gap: 18px;
    color: #777;
    margin-bottom: 30px;
}

.custom-divider span {
    flex: 1;
    height: 1px;
    background: #ddd;
}

.custom-login-box label {
    display: block;
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 8px;
}

.custom-login-box input {
    height: 54px;
    border: 1px solid #999;
    border-radius: 8px;
    margin-bottom: 28px;
    font-size: 18px;
}

.custom-forgot {
    display: inline-block;
    color: #43aebd;
    text-decoration: underline;
    margin-top: -18px;
    margin-bottom: 32px;
}

.custom-login-btn {
    width: 100%;
    height: 58px;
    border: 0;
    background: #52b7c5;
    color: #fff;
    font-size: 18px;
    font-weight: 700;
}

.custom-register {
    border-top: 1px solid #ddd;
    margin-top: 34px;
    padding-top: 22px;
    color: #555;
}

.custom-register a {
    color: #43aebd;
    font-weight: 600;
    text-decoration: underline;
}

.custom-login-right {
    background-size: cover;
    background-position: center;
}

@media (max-width: 900px) {
    .custom-login-page {
        grid-template-columns: 1fr;
    }

    .custom-login-right {
        display: none;
    }

    .custom-login-left {
        padding: 100px 24px 40px;
    }

    .custom-login-logo {
        left: 24px;
    }
}
</style>